task.spawn(function()
    local lastTime = os.clock()
    local frameCount = 0
    
    local fpsConnection
    fpsConnection = RunService.RenderStepped:Connect(function()
        frameCount = frameCount + 1
    end)

    while task.wait(0.5) do
        if not LabelFPS and not LabelPing and not LabelPlayer then 
            if fpsConnection then fpsConnection:Disconnect() end
            break 
        end
        
        local currentTime = os.clock()
        local deltaTime = currentTime - lastTime
        local calculatedFps = math.floor(frameCount / deltaTime)
        
        frameCount = 0
        lastTime = currentTime

        if LabelFPS then
            LabelFPS.Text = "   " .. calculatedFps .. " FPS"
            if calculatedFps >= 45 then
                LabelFPS.TextColor3 = Color3.fromRGB(0, 255, 137)
            elseif calculatedFps >= 25 then
                LabelFPS.TextColor3 = Color3.fromRGB(255, 200, 0)
            else
                LabelFPS.TextColor3 = Color3.fromRGB(255, 85, 85)
            end
        end

        if LabelPing then
            local pingValue = 0
            local successPing = pcall(function()
                pingValue = math.floor(LocalPlayer:GetNetworkPing() * 1000)
            end)
            
            if not successPing or pingValue <= 0 then
                pcall(function()
                    pingValue = math.floor(Stats.Network.ServerToClientPing:GetValue() * 1000)
                end)
            end
            
            LabelPing.Text = "   " .. pingValue .. " MS PING"
            if pingValue <= 90 then
                LabelPing.TextColor3 = Color3.fromRGB(0, 255, 137)
            elseif pingValue <= 200 then
                LabelPing.TextColor3 = Color3.fromRGB(255, 200, 0)
            else
                LabelPing.TextColor3 = Color3.fromRGB(255, 85, 85)
            end
        end

        if LabelPlayer then
            local currentPlayers = #Players:GetPlayers()
            LabelPlayer.Text = "   " .. currentPlayers .. " PLAYER"
            LabelPlayer.TextColor3 = Color3.fromRGB(0, 222, 255) -- Kustom warna Cyan Neon Cerah Estetik
