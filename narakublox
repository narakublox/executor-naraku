local function refreshSavedScripts()
    if not ScrollMain2 or not TemplateItem then return end

    -- 1. Bersihkan item lama secara aman (Hanya objek clone, template asli aman)
    for _, item in ipairs(ScrollMain2:GetChildren()) do
        if item:IsA("TextLabel") and item ~= TemplateItem then
            item:Destroy()
        end
    end

    -- 2. Suntikkan 4 Cloud Script Utama
    for _, cloudData in ipairs(CloudScripts) do
        local cloudItem = TemplateItem:Clone()
        cloudItem.Visible = true
        cloudItem.Parent = ScrollMain2

        -- Cari TextLabel anak di dalam template untuk menuliskan judul Title
        local titleLabel = cloudItem:FindFirstChildOfClass("TextLabel")
        if titleLabel then
            titleLabel.Text = cloudData.Name
            titleLabel.TextColor3 = Color3.fromRGB(210, 245, 255) -- Warna penanda cloud script pilihanmu
        else
            -- Fallback jika struktur textlabel terpasang langsung di parent
            cloudItem.Text = "   " .. cloudData.Name
        end

        local execBtn = cloudItem:FindFirstChild("ExecuteButton_24") or cloudItem:FindFirstChild("ExecuteButton") or cloudItem:FindFirstChildOfClass("TextButton")
        local delBtn = cloudItem:FindFirstChild("DeleteButton_28") or cloudItem:FindFirstChild("DeleteButton")

        if execBtn then
            execBtn.MouseButton1Click:Connect(function()
                task.spawn(function()
                    local success, content = pcall(function() return game:HttpGet(cloudData.Url) end)
                    if success and content and content ~= "" then
                        local func, err = loadstring(content)
                        if func then task.spawn(func) else warn("Cloud Exec Error: " .. tostring(err)) end
                    else
                        warn("Gagal mengunduh script dari Cloud Source.")
                    end
                end)
            end)
        end

        -- Cloud Script dilindungi total agar tidak bisa dihapus oleh player
        if delBtn then
            delBtn:Destroy()
        end
    end

    -- 3. Load File Hasil Simpanan Lokal (.txt atau .lua saja)
    local FOLDER_NAME = "DELTA"
    if listfiles and isfolder(FOLDER_NAME) then
        local successFiles, files = pcall(function() return listfiles(FOLDER_NAME) end)
        if successFiles and files then
            for _, filePath in ipairs(files) do
                local fileName = filePath:match("([^/\\]+)$") or filePath
                local lowerName = fileName:lower()

                -- Jalankan filter ketat ekstensi berkas arsip script lokal
                if lowerName:sub(-4) == ".txt" or lowerName:sub(-4) == ".lua" then
                    local cleanTitle = fileName:gsub("%.txt$", ""):gsub("%.lua$", "")

                    local newItem = TemplateItem:Clone()
                    newItem.Visible = true
                    newItem.Parent = ScrollMain2

                    -- Masukkan teks judul ke TextLabel anak agar desain kosmetikmu tetap terjaga
                    local titleLabel = newItem:FindFirstChildOfClass("TextLabel")
                    if titleLabel then
                        titleLabel.Text = cleanTitle
                    else
                        newItem.Text = "   " .. cleanTitle
                    end

                    local execBtn = newItem:FindFirstChild("ExecuteButton_24") or newItem:FindFirstChild("ExecuteButton") or newItem:FindFirstChildOfClass("TextButton")
                    local delBtn = newItem:FindFirstChild("DeleteButton_28") or newItem:FindFirstChild("DeleteButton")

                    if execBtn then
                        execBtn.MouseButton1Click:Connect(function()
                            local successRead, content = pcall(function() return readfile(filePath) end)
                            if successRead and content and content ~= "" then
                                local func, err = loadstring(content)
                                if func then task.spawn(func) else warn("Execution Error: " .. tostring(err)) end
                            end
                        end)
                    end

                    if delBtn then
                        delBtn.MouseButton1Click:Connect(function()
                            if delfile then
                                local successDel = pcall(function() delfile(filePath) end)
                                if successDel then newItem:Destroy() end
                            end
                        end)
                    end
                end
            end
        end
    end
end

